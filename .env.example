# ─── Database ────────────────────────────────────────
# Local SQLite (default):  file:data/blog.db
# Turso (managed):         libsql://your-db.turso.io
DATABASE_URL=file:data/blog.db
TURSO_AUTH_TOKEN=

# ─── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000
SITE_NAME=My Blog

# ─── Editor ──────────────────────────────────────────
# Set a password to protect the editor. Leave blank for open access.
EDITOR_PASSWORD=

# ─── Media storage ────────────────────────────────────
# Storage backend: "local" (default) or "gcs" (Google Cloud Storage).
MEDIA_STORAGE=local
# Local-only: directory path for uploads (default: media/).
MEDIA_DIR=media
# GCS-only: bucket name (required when MEDIA_STORAGE=gcs).
# GCS_BUCKET=
# GCS-only: path to service account JSON (optional on GCP with default credentials).
# GCS_KEY_FILE=
# GCS-only: custom public base URL for the bucket.
# GCS_PUBLIC_URL=https://storage.googleapis.com/your-bucket

# ─── Email subscriptions (optional) ──────────────────
# Set EMAIL_ENABLED=true to activate email subscriptions.
EMAIL_ENABLED=false

# Provider name. Built-in: "mailjet". You can register custom
# providers via registerEmailProvider() in your own code.
EMAIL_PROVIDER=mailjet

# Sender identity shown in outgoing emails.
EMAIL_FROM_NAME=My Blog
EMAIL_FROM_EMAIL=noreply@yourdomain.com

# ─── Mailjet credentials ─────────────────────────────
# Get these from https://app.mailjet.com → API Keys
MAILJET_API_KEY=
MAILJET_API_SECRET=
