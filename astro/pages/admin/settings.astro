---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { editorRequiresAuth, isAuthenticatedRequest } from "../../../src/editor/auth.js";
import { initDb } from "../../../src/shared/db.js";
import { DEFAULT_TENANT_ID } from "../../../src/shared/types.js";
import { getSubscriptionSettings, listAllSubscribers } from "../../../src/subscription/db.js";

if (editorRequiresAuth() && !isAuthenticatedRequest(Astro.request)) {
  return Astro.redirect("/admin/login");
}

const db = await initDb();
const settings = await getSubscriptionSettings(db, DEFAULT_TENANT_ID);
const subscribers = await listAllSubscribers(db, DEFAULT_TENANT_ID);

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function subscriberStatus(sub: { verified: boolean; unsubscribed: boolean }): string {
  if (sub.unsubscribed) return "unsubscribed";
  if (sub.verified) return "verified";
  return "pending";
}

function badgeClass(status: string): string {
  if (status === "verified") return "badge badge-published";
  if (status === "pending") return "badge badge-draft";
  return "badge badge-draft";
}

const verifiedCount = subscribers.filter(s => s.verified && !s.unsubscribed).length;
const pendingCount = subscribers.filter(s => !s.verified && !s.unsubscribed).length;
---
<AdminLayout title="Settings — Admin">
  <main class="container">
    <div class="editor-list">
      <div class="editor-list-header">
        <h2>Settings</h2>
      </div>

      <div class="editor-list-section">
        <h3>Email subscriptions</h3>
        <p class="hint">Allow readers to subscribe and receive email notifications when new posts are published.</p>

        <form method="POST" action="/admin/settings/save" class="settings-form">
          <div class="field">
            <label class="field-toggle">
              <input type="checkbox" name="enabled" checked={settings.enabled} />
              <span>Enable email subscriptions</span>
            </label>
          </div>

          <fieldset class="settings-fieldset">
            <legend>Mailgun configuration</legend>
            <p class="hint">Enter your Mailgun credentials. You can get these from <a href="https://app.mailgun.com" target="_blank" rel="noopener">app.mailgun.com</a>.</p>

            <div class="field">
              <label for="apiKey">API key</label>
              <input type="password" id="apiKey" name="apiKey" value={settings.apiKey} placeholder="key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" autocomplete="off" />
            </div>

            <div class="field">
              <label for="domain">Sending domain</label>
              <input type="text" id="domain" name="domain" value={settings.domain} placeholder="mg.yourdomain.com" />
            </div>

            <div class="field">
              <label for="fromName">From name</label>
              <input type="text" id="fromName" name="fromName" value={settings.fromName} placeholder="My Blog" />
            </div>

            <div class="field">
              <label for="fromEmail">From email</label>
              <input type="email" id="fromEmail" name="fromEmail" value={settings.fromEmail} placeholder="noreply@yourdomain.com" />
            </div>
          </fieldset>

          <div class="field">
            <button type="submit" class="btn btn-primary">Save settings</button>
          </div>
        </form>
      </div>

      <div class="editor-list-section">
        <h3>Subscribers <span class="subscriber-count">({verifiedCount} verified, {pendingCount} pending)</span></h3>

        {subscribers.length === 0 ? (
          <p class="editor-empty">No subscribers yet.</p>
        ) : (
          <table class="editor-table">
            <thead>
              <tr><th>Email</th><th>Status</th><th>Date</th><th></th></tr>
            </thead>
            <tbody>
              {subscribers.map((sub) => {
                const status = subscriberStatus(sub);
                return (
                  <tr>
                    <td>{sub.email}</td>
                    <td class="cell-status">
                      <span class={badgeClass(status)}>{status}</span>
                    </td>
                    <td class="cell-date">{formatDate(sub.createdAt)}</td>
                    <td class="cell-actions">
                      <form method="POST" action={`/admin/subscribers/delete/${sub.id}`}
                            onsubmit="return confirm('Delete this subscriber?')">
                        <button type="submit" class="btn btn-ghost btn-sm">delete</button>
                      </form>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>
    </div>
  </main>
</AdminLayout>

<style>
  .settings-form {
    max-width: 480px;
  }
  .settings-form .field {
    margin-bottom: 1rem;
  }
  .settings-form label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }
  .settings-form input[type="text"],
  .settings-form input[type="email"],
  .settings-form input[type="password"] {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--border, #ddd);
    border-radius: 4px;
    font-size: 0.9rem;
    background: var(--bg-input, #fff);
    color: var(--fg, #333);
  }
  .settings-fieldset {
    border: 1px solid var(--border, #ddd);
    border-radius: 6px;
    padding: 1rem;
    margin: 1rem 0;
  }
  .settings-fieldset legend {
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0 0.5rem;
  }
  .field-toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }
  .field-toggle input[type="checkbox"] {
    width: 1rem;
    height: 1rem;
  }
  .field-toggle span {
    font-size: 0.9rem;
  }
  .hint {
    font-size: 0.82rem;
    color: var(--fg-muted, #888);
    margin: 0.25rem 0 0.75rem;
  }
  .hint a {
    color: var(--fg-muted, #888);
  }
  .subscriber-count {
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--fg-muted, #888);
  }
  .cell-actions form {
    display: inline;
  }
  .btn-sm {
    font-size: 0.78rem;
    padding: 0.15rem 0.5rem;
  }
</style>
