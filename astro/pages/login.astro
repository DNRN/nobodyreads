---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getNavItems } from "../../src/content/db.js";
import { DEFAULT_TENANT_ID } from "../../src/shared/types.js";
import { getDbClient } from "../lib/db.js";
import { isFederationEnabled, getFederationConfig } from "../../src/federation/config.js";

const tenantId = process.env.TENANT_ID || DEFAULT_TENANT_ID;
const urlPrefix = process.env.URL_PREFIX || "";
const siteName = process.env.SITE_NAME || "nobodyreads.me";

const db = await getDbClient();
const navItems = await getNavItems(db, tenantId);

const error = Astro.url.searchParams.get("error");
const next = Astro.url.searchParams.get("next") || "";
const signupHref = next
  ? `${urlPrefix}/signup?next=${encodeURIComponent(next)}`
  : `${urlPrefix}/signup`;

const federationEnabled = isFederationEnabled();
const federationName = getFederationConfig()?.issuerName ?? "the community";
const federationLoginHref = next
  ? `${urlPrefix}/api/federation/login?next=${encodeURIComponent(next)}`
  : `${urlPrefix}/api/federation/login`;

const options = {
  title: `Log in — ${siteName}`,
  navItems,
  seo: { noIndex: true },
  urlPrefix,
  siteName,
};
---
<SiteLayout options={options}>
  <div class="nb-auth-card">
    <h2>Log in</h2>
    <p>Welcome back.</p>
    {error === "invalid" ? (
      <ul class="nb-form-errors">
        <li>Incorrect email or password.</li>
      </ul>
    ) : null}
    <form method="POST" action={`${urlPrefix}/api/members/login`}>
      <input type="hidden" name="next" value={next} />
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required autofocus />
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required />
      <button type="submit">Log in</button>
    </form>
    {federationEnabled ? (
      <p class="nb-auth-alt">
        <a href={federationLoginHref}>Sign in with {federationName}</a>
      </p>
    ) : null}
    <p class="nb-auth-alt">No account yet? <a href={signupHref}>Join</a></p>
  </div>
</SiteLayout>

<style is:global>
  .nb-auth-card {
    max-width: 380px;
    margin: 2rem auto;
  }
  .nb-auth-card form {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 1rem;
  }
  .nb-auth-card label {
    font-size: 0.85em;
    opacity: 0.8;
  }
  .nb-auth-card input {
    padding: 0.5rem 0.65rem;
    font: inherit;
    border: 1px solid currentColor;
    border-radius: 6px;
    background: transparent;
    color: inherit;
  }
  .nb-auth-card button {
    margin-top: 0.75rem;
    padding: 0.55rem 1rem;
    font: inherit;
    border: 1px solid currentColor;
    border-radius: 999px;
    background: transparent;
    color: inherit;
    cursor: pointer;
  }
  .nb-form-errors {
    padding-left: 1.1rem;
    color: #c0392b;
  }
  .nb-auth-alt {
    margin-top: 1rem;
    font-size: 0.9em;
  }
</style>
