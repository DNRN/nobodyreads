# ─── Database ────────────────────────────────────────
# Local SQLite (default):  file:data/blog.db
# Turso (managed):         libsql://your-db.turso.io
DATABASE_URL=file:data/blog.db
TURSO_AUTH_TOKEN=

# ─── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
SITE_URL=http://localhost:3000
SITE_NAME=My Blog
SITE_TAGLINE=Another simple blog engine. For writing mostly to yourself.

# ─── Editor ──────────────────────────────────────────
# Set a password to protect the editor. Leave blank for open access.
EDITOR_PASSWORD=

# ─── Media storage ────────────────────────────────────
# Media storage is configured via a JSON file, not env vars.
# Default location: config/storage.config.json (see config/storage.config.example.json).
# Without that file, uploads are stored locally in media/.
# Override the config file location if needed:
# STORAGE_CONFIG=/absolute/path/to/storage.config.json

# ─── Email subscriptions (optional) ──────────────────
# Email is configured via a JSON file, not env vars.
# Default location: config/email.config.json (see config/email.config.example.json).
# Without that file (or with "enabled": false), subscriptions stay off.
# Override the config file location if needed:
# EMAIL_CONFIG=/absolute/path/to/email.config.json
