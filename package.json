{
  "name": "nobodyreads",
  "version": "0.1.0",
  "description": "A simple, self-hosted blog engine. Markdown-first, server-rendered, zero client-side JS.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/db/schema/index.d.ts",
      "import": "./dist/db/schema/index.js"
    },
    "./storage": {
      "types": "./dist/media/storage.d.ts",
      "import": "./dist/media/storage.js"
    },
    "./email": {
      "types": "./dist/subscription/email.d.ts",
      "import": "./dist/subscription/email.js"
    },
    "./editor": {
      "types": "./dist/admin/client/index.d.ts",
      "import": "./dist/admin/client/index.js"
    },
    "./editor/milkdown": {
      "types": "./dist/admin/client/milkdown/index.d.ts",
      "import": "./dist/admin/client/milkdown/index.js"
    },
    "./editor/styles": "./public/editor.css",
    "./astro": {
      "types": "./dist/astro/index.d.ts",
      "import": "./dist/astro/index.js"
    },
    "./astro/context": {
      "types": "./dist/astro/context.d.ts",
      "import": "./dist/astro/context.js"
    },
    "./astro/SiteLayout": "./astro/layouts/SiteLayout.astro",
    "./astro/ShareBar": "./astro/components/ShareBar.astro",
    "./community": {
      "types": "./dist/community/index.d.ts",
      "import": "./dist/community/index.js"
    },
    "./federation": {
      "types": "./dist/federation/index.d.ts",
      "import": "./dist/federation/index.js"
    }
  },
  "bin": {
    "nobodyreads": "./dist/standalone.js"
  },
  "files": [
    "dist",
    "public",
    "astro/_injected",
    "astro/layouts",
    "astro/components",
    "config/storage.config.example.json",
    "config/email.config.example.json",
    "schema.sql",
    "robots.txt"
  ],
  "scripts": {
    "dev": "tsx watch src/standalone.ts",
    "dev:astro": "astro dev",
    "dev:client": "tsx scripts/build-client.ts --watch",
    "start": "NODE_ENV=production tsx src/standalone.ts",
    "build": "npm run build:client && astro build && tsc",
    "build:client": "tsx scripts/build-client.ts",
    "site:use-minimal-css": "tsx scripts/use-minimal-css.ts",
    "site:bootstrap": "tsx scripts/bootstrap-site.ts",
    "site:remove-site-script": "tsx scripts/remove-site-script.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "post": "tsx scripts/publish.ts"
  },
  "keywords": [
    "blog",
    "markdown",
    "self-hosted",
    "blogging",
    "seo",
    "sqlite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nobodyreads/nobodyreads"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.2",
    "@astrojs/svelte": "^7.2.5",
    "@google-cloud/storage": "^7.21.0",
    "@hono/node-server": "^1.19.12",
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.14.0",
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/kit": "^7.21.2",
    "astro": "^5.17.1",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.25.8",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.9",
    "marked": "^15.0.7",
    "openai": "^6.45.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.9",
    "svelte": "^5.56.3",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.0",
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@types/busboy": "^1.5.4",
    "@types/node": "^25.2.1",
    "codemirror": "^6.0.1",
    "crelt": "^1.0.6",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.4",
    "puppeteer-core": "^25.1.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "style-mod": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vite": "^6.4.1",
    "vitest": "^4.1.2"
  }
}
