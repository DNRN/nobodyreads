---
interface Props {
  url: string;
  title: string;
  excerpt?: string;
}

const { url, title, excerpt } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedText = encodeURIComponent(title);
const blueskyText = encodeURIComponent(`${title} ${url}`);
---

<div class="share-bar">
  <span class="share-bar__label">Share</span>
  <div class="share-bar__buttons">
    <button
      class="share-bar__btn share-bar__btn--copy"
      data-share-copy={url}
      type="button"
      aria-label="Copy link"
    >
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span>Copy link</span>
    </button>
    <a
      class="share-bar__btn"
      href={`https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedText}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on X"
    >
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      X
    </a>
    <a
      class="share-bar__btn"
      href={`https://bsky.app/intent/compose?text=${blueskyText}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Bluesky"
    >
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 568 501" fill="currentColor"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.209C491.866-1.611 568-28.906 568 57.947c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 323.8 536.444 388.56 473.333 453.32c-119.86 122.992-172.272-30.859-185.702-70.281-2.462-7.227-3.614-10.608-3.631-7.733-.017-2.875-1.169.506-3.631 7.733-13.43 39.422-65.842 193.273-185.702 70.281-63.111-64.76-33.889-129.52 80.653-149.07-65.72 11.185-139.6-7.295-159.875-79.748C9.945 203.66 0 75.293 0 57.947 0-28.906 76.134-1.611 123.121 33.664Z"/></svg>
      Bluesky
    </a>
    <button
      class="share-bar__btn share-bar__btn--mastodon"
      data-share-mastodon-text={`${title} ${url}`}
      type="button"
      aria-label="Share on Mastodon"
    >
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 74 79" fill="currentColor"><path d="M73.7014 17.9592C72.5616 9.62034 65.1774 3.04876 56.424 1.77536C54.9472 1.55682 49.3517 0.7320813 36.3901 0.7320813H36.2933C23.3281 0.7320813 20.5465 1.55682 19.0697 1.77536C10.56 3.01376 2.78877 9.08286 0.903306 17.5725C-0.00357372 21.7737 -0.0998071 26.3702 0.0650786 30.6278C0.30074 36.8748 0.349338 43.1128 0.914393 49.3338C1.31238 53.6958 2.0299 57.9921 3.07956 62.2116C4.92055 69.5683 12.1353 75.6388 19.2417 78.0786C26.8386 80.6442 35.0006 81.0568 42.8232 79.2604C43.7218 79.0533 44.607 78.8058 45.4776 78.5138C47.4484 77.8752 49.6946 77.1775 51.4052 76.0135C51.4629 75.9736 51.5107 75.9215 51.5447 75.8609C51.5787 75.8003 51.5979 75.7329 51.6015 75.6636V70.2504C51.5985 70.1861 51.5817 70.1232 51.5523 70.0659C51.523 70.0086 51.4817 69.9581 51.4315 69.9181C51.3813 69.8781 51.3231 69.8494 51.2609 69.8341C51.1987 69.8188 51.1341 69.8171 51.0712 69.8292C47.9218 70.5352 44.7078 70.8874 41.4853 70.8816C34.6507 70.8816 32.9012 67.592 32.3889 66.3616C31.9778 65.3125 31.7197 64.211 31.6203 63.0902C31.6205 63.0187 31.6395 62.9484 31.6754 62.8864C31.7113 62.8244 31.7627 62.7727 31.8247 62.7367C31.8867 62.7007 31.9571 62.6816 32.0287 62.6814C32.1003 62.6812 32.1707 62.7001 32.2329 62.7358C35.2071 63.4518 38.2575 63.8099 41.3174 63.8028C42.1787 63.8028 43.0353 63.8028 43.8967 63.7753C47.6513 63.6627 51.6382 63.4552 55.3234 62.7456C55.4155 62.7274 55.5076 62.7113 55.5887 62.6887C61.4981 61.5413 67.0981 57.9555 67.8967 48.9016C67.9282 48.5412 68.0123 44.1162 68.0123 43.7419C68.0303 42.4635 68.5354 31.2715 68.0123 22.8996C67.6289 16.9516 65.1774 12.7516 61.5354 9.4016C58.3964 6.49036 53.5404 4.04176 49.6094 3.47016C48.7594 3.34616 47.9094 3.22216 47.0594 3.09816C46.7038 3.05234 46.3422 3.03018 45.9804 3.03196H27.8904C27.5267 3.03196 27.1638 3.05534 26.8054 3.10316C25.9554 3.22716 25.1054 3.35116 24.2554 3.47516C20.3244 4.04676 15.4684 6.49536 12.3294 9.40636C8.68737 12.7564 6.23587 16.9564 5.85237 22.9044C5.32937 31.2724 5.83437 42.4644 5.85237 43.7419C5.85237 44.1162 5.93637 48.5412 5.96787 48.9016C6.76637 57.9555 12.3664 61.5413 18.2759 62.6887C18.3561 62.7113 18.4484 62.7274 18.5413 62.7456C22.2265 63.4552 26.2133 63.6627 29.968 63.7753C30.8293 63.8028 31.686 63.8028 32.5473 63.8028C35.6072 63.8099 38.6576 63.4518 41.6318 62.7358C41.694 62.7001 41.7644 62.6812 41.836 62.6814C41.9076 62.6816 41.978 62.7007 42.04 62.7367C42.102 62.7727 42.1534 62.8244 42.1893 62.8864C42.2252 62.9484 42.2442 63.0187 42.2444 63.0902C42.145 64.211 41.8869 65.3125 41.4758 66.3616C40.9635 67.592 39.214 70.8816 32.3794 70.8816C29.1569 70.8874 25.9429 70.5352 22.7935 69.8292C22.7306 69.8171 22.666 69.8188 22.6038 69.8341C22.5416 69.8494 22.4834 69.8781 22.4332 69.9181C22.383 69.9581 22.3417 70.0086 22.3124 70.0659C22.283 70.1232 22.2662 70.1861 22.2632 70.2504V75.6636C22.2668 75.7329 22.286 75.8003 22.32 75.8609C22.354 75.9215 22.4018 75.9736 22.4595 76.0135C24.1701 77.1775 26.4163 77.8752 28.3871 78.5138C29.2577 78.8058 30.1429 79.0533 31.0415 79.2604C38.8641 81.0568 47.0261 80.6442 54.623 78.0786C61.7294 75.6388 68.9441 69.5683 70.7851 62.2116C71.8348 57.9921 72.5523 53.6958 72.9503 49.3338C73.5154 43.1128 73.5640 36.8748 73.7996 30.6278C73.9645 26.3702 73.8683 21.7737 72.9616 17.5725L73.7014 17.9592Z"/></svg>
      Mastodon
    </button>
    <a
      class="share-bar__btn"
      href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Facebook"
    >
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      Facebook
    </a>
    <a
      class="share-bar__btn"
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on LinkedIn"
    >
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      LinkedIn
    </a>
  </div>
</div>

<script>
  // Copy link button
  document.querySelectorAll<HTMLButtonElement>("[data-share-copy]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = btn.dataset.shareCopy!;
      try {
        await navigator.clipboard.writeText(url);
        const span = btn.querySelector("span");
        if (span) {
          const original = span.textContent;
          span.textContent = "Copied!";
          setTimeout(() => { span.textContent = original; }, 2000);
        }
      } catch {
        // Fallback: select a temporary input
        const input = document.createElement("input");
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand("copy");
        document.body.removeChild(input);
      }
    });
  });

  // Mastodon: prompt for instance
  document.querySelectorAll<HTMLButtonElement>("[data-share-mastodon-text]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const text = btn.dataset.shareMastodonText!;
      const instance = window.prompt("Enter your Mastodon instance (e.g. mastodon.social):");
      if (!instance) return;
      const clean = instance.trim().replace(/^https?:\/\//, "").replace(/\/$/, "");
      window.open(
        `https://${clean}/share?text=${encodeURIComponent(text)}`,
        "_blank",
        "noopener,noreferrer"
      );
    });
  });
</script>

<style>
  .share-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border, #e5e7eb);
    font-size: 0.875rem;
  }

  .share-bar__label {
    color: var(--color-muted, #6b7280);
    font-weight: 500;
    margin-right: 0.25rem;
  }

  .share-bar__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .share-bar__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 0.375rem;
    background: transparent;
    color: var(--color-text, inherit);
    font-size: 0.8125rem;
    font-family: inherit;
    cursor: pointer;
    text-decoration: none;
    line-height: 1;
    transition: background 0.15s, border-color 0.15s;
  }

  .share-bar__btn:hover {
    background: var(--color-surface-hover, #f3f4f6);
    border-color: var(--color-border-hover, #d1d5db);
  }

  .share-bar__btn svg {
    flex-shrink: 0;
  }
</style>
