---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdminContext } from "nobodyreads/astro/context";
import { initDb, listAllPages } from "nobodyreads";

const ctx = requireAdminContext(Astro.locals);

const db = await initDb();
const pages = await listAllPages(db, ctx.tenantId);

const posts = pages.filter((p) => p.kind === "post");
const staticPages = pages.filter((p) => p.kind === "page");
const homePage = pages.find((p) => p.kind === "home");
const publishedPosts = posts.filter((p) => p.published).length;
const drafts = pages.filter((p) => !p.published).length;

const recent = [...posts].sort((a, b) => (a.date < b.date ? 1 : -1)).slice(0, 5);

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
}

// First-run checklist — nudges a brand-new site toward a real first post. Hidden
// once every step is done so it doesn't clutter an established site.
const checklist = [
  {
    done: !!homePage,
    label: "Set up your home page",
    href: homePage ? `${ctx.editorBase}/${homePage.id}` : `${ctx.editorBase}/new?kind=home`,
  },
  { done: posts.length > 0, label: "Write your first post", href: `${ctx.editorBase}/new?kind=post` },
  { done: publishedPosts > 0, label: "Publish a post", href: ctx.editorBase },
];
const setupComplete = checklist.every((c) => c.done);
---
<AdminLayout title="Home — Admin" adminBase={ctx.adminBase} siteBase={ctx.siteBase}>
  <main class="container">
    <div class="dashboard-header">
      <div>
        <h2>Home</h2>
        <p>Write, publish, and shape your site.</p>
      </div>
      <a href={`${ctx.editorBase}/new?kind=post`} class="btn btn-primary">Write a post</a>
    </div>

    {!setupComplete ? (
      <div class="editor-list-section">
        <h3>Get started</h3>
        <ul class="dashboard-checklist">
          {checklist.map((step) => (
            <li class:list={["dashboard-check", { done: step.done }]}>
              <span class="dashboard-check-mark">{step.done ? "✓" : "○"}</span>
              {step.done ? <span>{step.label}</span> : <a href={step.href}>{step.label}</a>}
            </li>
          ))}
        </ul>
      </div>
    ) : null}

    <div class="dashboard-stats">
      <div class="dashboard-stat">
        <span class="dashboard-stat-num">{publishedPosts}</span>
        <span class="dashboard-stat-label">Published posts</span>
      </div>
      <div class="dashboard-stat">
        <span class="dashboard-stat-num">{staticPages.length}</span>
        <span class="dashboard-stat-label">Pages</span>
      </div>
      <div class="dashboard-stat">
        <span class="dashboard-stat-num">{drafts}</span>
        <span class="dashboard-stat-label">Drafts</span>
      </div>
    </div>

    <div class="editor-list-section">
      <div class="editor-list-header">
        <h3>Recent posts</h3>
        <a href={ctx.editorBase} class="btn btn-sm btn-ghost">All content</a>
      </div>
      {recent.length === 0 ? (
        <p class="editor-empty">
          No posts yet. <a href={`${ctx.editorBase}/new?kind=post`}>Write your first one.</a>
        </p>
      ) : (
        <table class="editor-table">
          <thead><tr><th>Title</th><th>Status</th><th>Date</th></tr></thead>
          <tbody>
            {recent.map((p) => (
              <tr>
                <td><a href={`${ctx.editorBase}/${p.id}`}>{p.title}</a></td>
                <td class="cell-status">
                  {p.published
                    ? <span class="badge badge-published">published</span>
                    : <span class="badge badge-draft">draft</span>}
                </td>
                <td class="cell-date">{formatDate(p.date)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <div class="dashboard-grid">
      <a href={`${ctx.adminBase}/layout`} class="dashboard-card">
        <h3>Design</h3>
        <p>Edit your site template, colors, and structure.</p>
      </a>
      <a href={`${ctx.adminBase}/media`} class="dashboard-card">
        <h3>Media</h3>
        <p>Upload and manage images and files.</p>
      </a>
      <a href={`${ctx.adminBase}/settings`} class="dashboard-card">
        <h3>Settings</h3>
        <p>Site identity, email, and configuration.</p>
      </a>
    </div>
  </main>
</AdminLayout>
