---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SiteEditor from "../../components/admin/SiteEditor.svelte";
import { requireAdminContext } from "nobodyreads/astro/context";
import {
  initDb,
  DEFAULT_TEMPLATE,
  generateHtml,
  getSiteTemplate,
  listSiteTemplateRevisions,
  getCurrentSiteTemplateRevisionId,
  serializeRegistry,
  normalizeComponents,
} from "nobodyreads";
import type { ComponentMap } from "nobodyreads";

const ctx = requireAdminContext(Astro.locals);
const layoutBase = `${ctx.adminBase}/layout`;
const themeBase = `${ctx.adminBase}/theme`;
const previewUrl = `${ctx.siteBase.replace(/\/$/, "")}/preview`;

const db = await initDb();
const template = (await getSiteTemplate(db, ctx.tenantId)) ?? DEFAULT_TEMPLATE;
const revisions = await listSiteTemplateRevisions(db, ctx.tenantId);
const currentRevisionId = await getCurrentSiteTemplateRevisionId(db, ctx.tenantId);

const layoutHtml = template.layoutHtml ?? "";
const customCss = template.customCss ?? "";
const customJs = template.customJs ?? "";
const customTokens = template.customTokens ?? [];
const themeMeta = template.themeMeta ?? null;
const templateJson = JSON.stringify(template, null, 2);
const componentRegistry = serializeRegistry();
const componentConfigs: ComponentMap = normalizeComponents(template.components);

const generatedHtml = generateHtml({ ...template, layoutHtml: undefined });

const builtinTokens = [
  { token: "{{content}}", description: "Page/post body content" },
  { token: "{{nav}}", description: "Navigation links" },
  { token: "{{subscribe}}", description: "Email subscribe form" },
  { token: "{{siteName}}", description: "Site name" },
  { token: "{{siteTagline}}", description: "Site tagline" },
  { token: "{{siteBranding}}", description: "Logo image, or site name when no logo is set" },
  { token: "{{siteLogo}}", description: "Logo image URL (empty when unset)" },
  { token: "{{homeHref}}", description: "Home page URL" },
  { token: "{{year}}", description: "Current year" },
];

function formatDateTime(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}
---
<AdminLayout
  title="Theme Editor — Admin"
  adminBase={ctx.adminBase}
  siteBase={ctx.siteBase}
>
  <main class="editor-main editor-main--site">
    <SiteEditor
      client:load
      layoutBase={layoutBase}
      adminBase={ctx.adminBase}
      templateJson={templateJson}
      layoutHtml={layoutHtml}
      generatedHtml={generatedHtml}
      customCss={customCss}
      customJs={customJs}
      customTokens={customTokens}
      builtinTokens={builtinTokens}
      componentRegistry={componentRegistry}
      componentConfigs={componentConfigs}
      previewUrl={previewUrl}
    />

    <!-- Theme Import / Export -->
    <div class="editor-list-section">
      <h3>Theme</h3>
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
        <a href={`${themeBase}/export`} class="btn btn-ghost" download>Export theme</a>

        <form method="POST" action={`${themeBase}/import`} enctype="multipart/form-data" class="editor-inline-form" style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="file" name="file" accept=".json,application/json" class="editor-input editor-input--sm" />
          <button type="submit" class="btn btn-ghost">Import theme</button>
        </form>

        {themeMeta && (
          <span class="hint" style="margin-left: 0.5rem">
            Current: <strong>{themeMeta.name}</strong> v{themeMeta.version} by {themeMeta.author}
          </span>
        )}
      </div>
    </div>

    <!-- Revisions -->
    <div class="editor-list-section">
      <h3>Revisions</h3>
      {revisions.length === 0 ? (
        <p class="editor-empty">No revisions yet. Save your first change.</p>
      ) : (
        <table class="editor-table">
          <thead>
            <tr><th>ID</th><th>Saved</th><th>Status</th><th>Actions</th></tr>
          </thead>
          <tbody>
            {revisions.map((rev) => {
              const isCurrent = currentRevisionId === rev.revisionId;
              const meta = (rev.template as any)?.themeMeta;
              return (
                <tr>
                  <td>
                    #{rev.revisionId}
                    {meta?.name ? <span class="hint" style="margin-left: 0.25rem">({meta.name})</span> : null}
                  </td>
                  <td>{formatDateTime(rev.createdAt)}</td>
                  <td>
                    {isCurrent
                      ? <span class="badge badge-published">published</span>
                      : <span class="badge badge-draft">draft</span>}
                  </td>
                  <td class="cell-actions">
                    {!isCurrent ? (
                      <form
                        method="POST"
                        action={`${layoutBase}/revision/publish/${rev.revisionId}`}
                        class="editor-inline-form"
                      >
                        <button type="submit" class="btn btn-primary btn-sm">Publish</button>
                      </form>
                    ) : null}
                    <form
                      method="POST"
                      action={`${layoutBase}/revision/delete/${rev.revisionId}`}
                      class="editor-inline-form"
                      onsubmit="return confirm('Delete this revision?')"
                    >
                      <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>
  </main>
</AdminLayout>
