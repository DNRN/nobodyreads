---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import ViewEditorForm from "../../../components/admin/ViewEditorForm.astro";
import { editorRequiresAuth, isAuthenticatedRequest } from "../../../../src/editor/auth.js";

if (editorRequiresAuth() && !isAuthenticatedRequest(Astro.request)) {
  return Astro.redirect("/admin/login");
}
---
<AdminLayout title="New View — Admin" scripts={`<script src="/view-editor.js"></script>`}>
  <ViewEditorForm viewsBase="/admin/views" />
</AdminLayout>
