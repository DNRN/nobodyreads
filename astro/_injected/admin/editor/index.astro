---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { requireAdminContext } from "nobodyreads/astro/context";
import { initDb, listAllPages, type Page } from "nobodyreads";

const ctx = requireAdminContext(Astro.locals);

const db = await initDb();
const pages = await listAllPages(db, ctx.tenantId);

const groups: Record<string, Page[]> = { home: [], page: [], post: [] };
for (const page of pages) {
  const bucket = groups[page.kind] ?? [];
  bucket.push(page);
  groups[page.kind] = bucket;
}

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function kindLabel(kind: string): string {
  if (kind === "home") return "Home";
  if (kind === "post") return "Post";
  return "Page";
}

function viewUrl(p: Page): string {
  if (p.kind === "post") return `${ctx.siteBase.replace(/\/$/, "")}/posts/${p.slug}`;
  if (p.kind === "home") return ctx.siteBase;
  return `${ctx.siteBase.replace(/\/$/, "")}/${p.slug}`;
}

// Only one home page per site — if it exists, offer editing instead of creating.
const homePage = groups.home[0];

const createOptions = [
  {
    kind: "post",
    label: "Post",
    description: "A blog post. Shows up in your feed and is sent to subscribers when published.",
    href: `${ctx.editorBase}/new?kind=post`,
    cta: "New post",
  },
  {
    kind: "page",
    label: "Page",
    description: "A standalone page like About or Contact. Can be added to the navigation.",
    href: `${ctx.editorBase}/new?kind=page`,
    cta: "New page",
  },
];
---
<AdminLayout title="Content — Admin" adminBase={ctx.adminBase} siteBase={ctx.siteBase}>
  <main class="container">
    <div class="editor-list">
      <div class="editor-list-header">
        <h2>Content</h2>
      </div>
      <div class="editor-create">
        {createOptions.map((opt) => (
          <a href={opt.href} class="editor-create-card" data-kind={opt.kind}>
            <strong class="editor-create-title">{opt.label}</strong>
            <span class="editor-create-desc">{opt.description}</span>
            <span class="btn btn-sm btn-primary editor-create-cta">{opt.cta}</span>
          </a>
        ))}
      </div>
      <section class="editor-home" aria-label="Site identity">
        <div class="editor-home-main">
          <span class="editor-home-label">Site identity</span>
          <a href={`${ctx.editorBase}/site`} class="editor-home-title">
            Name, tagline, logo, favicon &amp; social image
          </a>
        </div>
        <div class="editor-home-meta">
          <a href={`${ctx.editorBase}/site`} class="btn btn-sm btn-ghost">Edit</a>
        </div>
      </section>
      <section class="editor-home" aria-label="Home page">
        <div class="editor-home-main">
          <span class="editor-home-label">Home</span>
          {homePage ? (
            <a href={`${ctx.editorBase}/${homePage.id}`} class="editor-home-title">{homePage.title}</a>
          ) : (
            <p class="editor-home-empty">The front page of your site. Every site has exactly one.</p>
          )}
        </div>
        <div class="editor-home-meta">
          {homePage ? (
            <>
              {homePage.published
                ? <span class="badge badge-published">published</span>
                : <span class="badge badge-draft">draft</span>}
              <span class="editor-home-date">Last edited {formatDate(homePage.date)}</span>
            </>
          ) : (
            <a href={`${ctx.editorBase}/new?kind=home`} class="btn btn-sm btn-primary">Create home</a>
          )}
        </div>
      </section>
      {pages.length === 0 ? (
        <p class="editor-empty">No pages yet. Create your first one!</p>
      ) : null}
      {(["page", "post"] as const).map((kind) => {
        const items = groups[kind];
        if (items.length === 0) return null;
        return (
          <div class="editor-list-section">
            <h3>{kindLabel(kind)}s</h3>
            <table class="editor-table">
              <thead>
                <tr><th>Title</th><th>URL</th><th>Status</th><th>Date</th></tr>
              </thead>
              <tbody>
                {items.map((p) => (
                  <tr>
                    <td><a href={`${ctx.editorBase}/${p.id}`}>{p.title}</a></td>
                    <td class="cell-slug">{viewUrl(p)}</td>
                    <td class="cell-status">
                      {p.published
                        ? <span class="badge badge-published">published</span>
                        : <span class="badge badge-draft">draft</span>}
                    </td>
                    <td class="cell-date">{formatDate(p.date)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        );
      })}
    </div>
  </main>
</AdminLayout>
