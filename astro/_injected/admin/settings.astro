---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdminContext } from "nobodyreads/astro/context";
import { isEmailEnabled } from "nobodyreads";

const ctx = requireAdminContext(Astro.locals);

const emailEnabled = isEmailEnabled();
---
<AdminLayout title="Settings — Admin" adminBase={ctx.adminBase} siteBase={ctx.siteBase}>
  <main class="container">
    <div class="editor-list">
      <div class="editor-list-header">
        <h2>Settings</h2>
      </div>

      <section class="editor-home" aria-label="Site identity">
        <div class="editor-home-main">
          <span class="editor-home-label">Site identity</span>
          <a href={`${ctx.editorBase}/site`} class="editor-home-title">
            Name, tagline, logo, favicon &amp; social image
          </a>
        </div>
        <div class="editor-home-meta">
          <a href={`${ctx.editorBase}/site`} class="btn btn-sm btn-ghost">Edit</a>
        </div>
      </section>

      <div class="editor-list-section">
        <h3>Email subscriptions</h3>

        <div class="env-status">
          <div class="env-row">
            <span class="env-label">Status</span>
            <span class={emailEnabled ? "env-value env-on" : "env-value env-off"}>
              {emailEnabled ? "Enabled" : "Disabled"}
            </span>
          </div>
        </div>
        <p class="hint">
          Subscriber numbers live under <a href={`${ctx.adminBase}/community`}>Community</a>.
        </p>
      </div>
    </div>
  </main>
</AdminLayout>
