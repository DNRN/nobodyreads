---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdminContext } from "nobodyreads/astro/context";
import { initDb, isEmailEnabled, countSubscribers } from "nobodyreads";

const ctx = requireAdminContext(Astro.locals);

const db = await initDb();
const counts = await countSubscribers(db, ctx.tenantId);

const emailEnabled = isEmailEnabled();
---
<AdminLayout title="Settings — Admin" adminBase={ctx.adminBase} siteBase={ctx.siteBase}>
  <main class="container">
    <div class="editor-list">
      <div class="editor-list-header">
        <h2>Settings</h2>
      </div>

      <div class="editor-list-section">
        <h3>Email subscriptions</h3>

        <div class="env-status">
          <div class="env-row">
            <span class="env-label">Status</span>
            <span class={emailEnabled ? "env-value env-on" : "env-value env-off"}>
              {emailEnabled ? "Enabled" : "Disabled"}
            </span>
          </div>
        </div>
      </div>

      <div class="editor-list-section">
        <h3>Subscribers</h3>

        <div class="env-status">
          <div class="env-row">
            <span class="env-label">Confirmed</span>
            <span class="env-value">{counts.verified}</span>
          </div>
          <div class="env-row">
            <span class="env-label">Pending confirmation</span>
            <span class="env-value">{counts.pending}</span>
          </div>
          <div class="env-row">
            <span class="env-label">Unsubscribed</span>
            <span class="env-value">{counts.unsubscribed}</span>
          </div>
        </div>
      </div>
    </div>
  </main>
</AdminLayout>
