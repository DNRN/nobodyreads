---
import type { LayoutOptions } from "../../src/content/types.js";
import { escapeHtml } from "../../src/shared/http.js";
import { buildMetaTags, buildStructuredData, navHref } from "../../src/shared/seo.js";
import { initDb } from "../../src/shared/db.js";
import { DEFAULT_TENANT_ID } from "../../src/shared/types.js";
import { getSiteTemplate } from "../../src/shared/site-bundle.js";
import {
  getSiteSettings,
  resolveSiteIdentity,
  resolveMediaValue,
} from "../../src/shared/site-settings.js";
import { createMediaStorage } from "../../src/media/storage.js";
import ClientRouter from "astro/components/ClientRouter.astro";
import type { SiteTemplateDefinition } from "../../src/template/types.js";
import { generateCss, generateHtml } from "../../src/template/generate.js";
import { DEFAULT_TEMPLATE } from "../../src/template/defaults.js";
import { isEmailEnabled } from "../../src/subscription/email.js";

const { options, authLinksHtml, templateOverride, showCommunity = true } = Astro.props as {
  options: LayoutOptions;
  authLinksHtml?: string;
  templateOverride?: SiteTemplateDefinition | null;
  showCommunity?: boolean;
};

const db = await initDb();
const settings = await getSiteSettings(db, DEFAULT_TENANT_ID);
const templateDef: SiteTemplateDefinition =
  templateOverride ?? (await getSiteTemplate(db, DEFAULT_TENANT_ID)) ?? DEFAULT_TEMPLATE;

const identity = resolveSiteIdentity(settings, {
  siteName: "nobodyreads.me",
  siteTagline: "Another simple blog engine. For writing mostly to yourself.",
});
const siteName = options.siteName ?? identity.siteName;
const siteTagline = options.siteTagline ?? identity.siteTagline;

const storage = createMediaStorage();
const mediaUrl = (key: string) => storage.url(key);
const logoUrl = resolveMediaValue(identity.logo, mediaUrl);
const faviconUrl = resolveMediaValue(identity.favicon, mediaUrl);
const ogImageUrl = resolveMediaValue(identity.ogImage, mediaUrl);

const homeHref = options.urlPrefix || "/";
const navItems = options.navItems ?? [];
const activePageId = options.activePageId;

const metaOptions = { ...options, siteName, siteTagline, defaultOgImage: ogImageUrl ?? undefined };
const metaTags = buildMetaTags(metaOptions);
const structuredData = buildStructuredData(metaOptions);

const faviconTags = faviconUrl
  ? `  <link rel="icon" href="${escapeHtml(faviconUrl)}">\n  <link rel="apple-touch-icon" href="${escapeHtml(faviconUrl)}">`
  : "";

const brandingHtml = logoUrl
  ? `<img class="site-logo" src="${escapeHtml(logoUrl)}" alt="${escapeHtml(siteName)}">`
  : escapeHtml(siteName);

const scriptTags = (options.scripts ?? [])
  .map((s) => `  <script type="module" src="${escapeHtml(s)}"></script>`)
  .join("\n");

const devReload = import.meta.env.DEV
  ? `  <script>new EventSource("/__reload").onmessage = e => { if (e.data === "reload") location.reload(); };</script>`
  : "";

const emailEnabled = isEmailEnabled();

const subscribeFormHtml = emailEnabled
  ? `<form class="nb-subscribe" method="POST" action="/api/subscribe">
      <input type="email" name="email" class="site-input" placeholder="Your email" required />
      <button type="submit" class="site-button">Subscribe</button>
     </form>`
  : "";

const slotHtml = await Astro.slots.render("default");
const navHtml = navItems
  .map((item) => {
    const href = escapeHtml(navHref(item, options.urlPrefix));
    const label = escapeHtml(item.label);
    const active = item.id === activePageId ? ' class="active"' : "";
    return `<a href="${href}"${active}>${label}</a>`;
  })
  .join("");
const authLinksBlock = authLinksHtml
  ? `<nav class="site-menu" id="site-menu" data-nav aria-label="Profile">
      <span class="nav-auth nav-auth--menu">${authLinksHtml}</span>
     </nav>`
  : "";
const communityApiBase = `${options.urlPrefix || ""}/api`;
const communityLoginHref = `${options.urlPrefix || ""}/login`;
const communityBlock = showCommunity
  ? `<div class="nb-community nb-community--topbar" data-community data-join-only data-api-base="${escapeHtml(communityApiBase)}" data-login-href="${escapeHtml(communityLoginHref)}"></div>`
  : "";
const navToggle = authLinksHtml
  ? `<button class="nav-toggle" type="button" data-nav-toggle aria-label="Toggle menu" aria-controls="site-menu" aria-expanded="false">
      <span></span><span></span><span></span>
     </button>`
  : "";

const templateHtml = generateHtml(templateDef);
const hasSubscribeToken = templateHtml.includes("{{subscribe}}");
let bodyHtml = templateHtml
  .replaceAll("{{nav}}", navHtml)
  .replaceAll("{{communityBlock}}", communityBlock)
  .replaceAll("{{authLinksBlock}}", authLinksBlock)
  .replaceAll("{{navToggle}}", navToggle)
  .replaceAll("{{siteName}}", escapeHtml(siteName))
  .replaceAll("{{siteTagline}}", escapeHtml(siteTagline))
  .replaceAll("{{siteBranding}}", brandingHtml)
  .replaceAll("{{siteLogo}}", logoUrl ? escapeHtml(logoUrl) : "")
  .replaceAll("{{homeHref}}", escapeHtml(homeHref))
  .replaceAll("{{year}}", `${new Date().getFullYear()}`)
  .replaceAll("{{subscribe}}", subscribeFormHtml);

const autoInjectSubscribe =
  emailEnabled && !hasSubscribeToken && options.page?.kind === "post";
const contentHtml = autoInjectSubscribe ? `${slotHtml}\n${subscribeFormHtml}` : slotHtml;

bodyHtml = bodyHtml.includes("{{content}}")
  ? bodyHtml.replaceAll("{{content}}", contentHtml)
  : `${bodyHtml}\n${contentHtml}`;

if (templateDef.customTokens?.length) {
  for (const token of templateDef.customTokens) {
    const value = settings[`custom_token:${token.key}`] ?? token.defaultValue;
    const rendered = token.type === "html" ? value : escapeHtml(value);
    bodyHtml = bodyHtml.replaceAll(`{{${token.key}}}`, rendered);
  }
}

const generatedCss = generateCss(templateDef);
const customJs = templateDef.customJs?.trim() || "";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{options.title}</title>
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = (stored === "system" || !stored)
            ? (prefersDark ? "dark" : "light")
            : (stored === "dark" || stored === "light"
                ? stored
                : (prefersDark ? "dark" : "light"));
          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    {faviconTags ? <Fragment set:html={faviconTags} /> : null}
    <Fragment set:html={metaTags} />
    <Fragment set:html={structuredData} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
    />
    <style is:global>
      .post-body img,
      .page-body img,
      .home-intro img {
        max-width: 100%;
        height: auto;
      }
      html {
        scrollbar-gutter: stable;
      }
      .site-header {
        view-transition-name: nr-header;
      }
      .site-footer {
        view-transition-name: nr-footer;
      }
    </style>
    <style id="nr-generated-css" set:html={generatedCss} />
    <Fragment set:html={scriptTags} />
    <Fragment set:html={devReload} />
    <ClientRouter />
    <script>
      // Preserve data-theme across navigations — Astro's swap removes all html
      // attributes, which would cause a flash on dark-mode sites.
      document.addEventListener("astro:before-swap", (e) => {
        const theme = document.documentElement.dataset.theme;
        if (theme) (e as any).newDocument.documentElement.dataset.theme = theme;
      });
    </script>
  </head>
  <body>
    <Fragment set:html={bodyHtml} />
    {customJs ? <script type="module" set:html={customJs} /> : null}
    {showCommunity ? <script src="/community.js" defer /> : null}
    <script src="/site.js" defer></script>
  </body>
</html>
