---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { editorRequiresAuth, isAuthenticatedRequest } from "../../../src/editor/auth.js";
import { initDb } from "../../../src/shared/db.js";
import { DEFAULT_TENANT_ID } from "../../../src/shared/types.js";
import { listAllSubscribers } from "../../../src/subscription/db.js";
import { isEmailEnabled } from "../../../src/subscription/email.js";

if (editorRequiresAuth() && !isAuthenticatedRequest(Astro.request)) {
  return Astro.redirect("/admin/login");
}

const db = await initDb();
const subscribers = await listAllSubscribers(db, DEFAULT_TENANT_ID);

const emailEnabled = isEmailEnabled();
const emailProvider = process.env.EMAIL_PROVIDER || "(not set)";
const emailFrom = process.env.EMAIL_FROM_EMAIL || "(not set)";

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function subscriberStatus(sub: { verified: boolean; unsubscribed: boolean }): string {
  if (sub.unsubscribed) return "unsubscribed";
  if (sub.verified) return "verified";
  return "pending";
}

function badgeClass(status: string): string {
  if (status === "verified") return "badge badge-published";
  if (status === "pending") return "badge badge-draft";
  return "badge badge-draft";
}

const verifiedCount = subscribers.filter(s => s.verified && !s.unsubscribed).length;
const pendingCount = subscribers.filter(s => !s.verified && !s.unsubscribed).length;
---
<AdminLayout title="Settings — Admin">
  <main class="container">
    <div class="editor-list">
      <div class="editor-list-header">
        <h2>Settings</h2>
      </div>

      <div class="editor-list-section">
        <h3>Email subscriptions</h3>
        <p class="hint">Email subscriptions are configured via environment variables.</p>

        <div class="env-status">
          <div class="env-row">
            <span class="env-label">Status</span>
            <span class={emailEnabled ? "env-value env-on" : "env-value env-off"}>
              {emailEnabled ? "Enabled" : "Disabled"}
            </span>
          </div>
          <div class="env-row">
            <span class="env-label">Provider</span>
            <span class="env-value">{emailProvider}</span>
          </div>
          <div class="env-row">
            <span class="env-label">From</span>
            <span class="env-value">{emailFrom}</span>
          </div>
        </div>

        <p class="hint">
          Set <code>EMAIL_ENABLED</code>, <code>EMAIL_PROVIDER</code>, <code>EMAIL_FROM_EMAIL</code>,
          and the provider-specific keys in your <code>.env</code> file. See <code>.env.example</code> for details.
        </p>
      </div>

      <div class="editor-list-section">
        <h3>Subscribers <span class="subscriber-count">({verifiedCount} verified, {pendingCount} pending)</span></h3>

        {subscribers.length === 0 ? (
          <p class="editor-empty">No subscribers yet.</p>
        ) : (
          <table class="editor-table">
            <thead>
              <tr><th>Email</th><th>Status</th><th>Date</th><th></th></tr>
            </thead>
            <tbody>
              {subscribers.map((sub) => {
                const status = subscriberStatus(sub);
                return (
                  <tr>
                    <td>{sub.email}</td>
                    <td class="cell-status">
                      <span class={badgeClass(status)}>{status}</span>
                    </td>
                    <td class="cell-date">{formatDate(sub.createdAt)}</td>
                    <td class="cell-actions">
                      <form method="POST" action={`/admin/subscribers/delete/${sub.id}`}
                            onsubmit="return confirm('Delete this subscriber?')">
                        <button type="submit" class="btn btn-ghost btn-sm">delete</button>
                      </form>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>
    </div>
  </main>
</AdminLayout>

